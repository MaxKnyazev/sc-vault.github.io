STALCRAFT_API_CLIENT_ID=
STALCRAFT_API_CLIENT_SECRET=

# Браузерный бандл: токен будет виден в собранном файле. Только для личного/тестового использования.
VITE_STALCRAFT_API_TOKEN=
VITE_STALCRAFT_API_CLIENT_ID=
VITE_STALCRAFT_API_CLIENT_SECRET=
# База URL для API аукциона. Локально в dev по умолчанию — прокси Vite (/stalcraft-eapi).
# На GitHub Pages: в CI задаётся автоматически после деплоя воркера (секрет CLOUDFLARE_API_TOKEN).
# Вручную: URL воркера из infra/stalcraft-cors-proxy (см. README там).
# VITE_STALCRAFT_API_BASE_URL=https://your-worker.workers.dev
# VITE_STALCRAFT_AUCTION_REGION=ru
# Параллельных запросов при массовом обновлении (1–16, по умолчанию 6; при 429 уменьшить)
# VITE_STALCRAFT_AUCTION_CONCURRENCY=6
